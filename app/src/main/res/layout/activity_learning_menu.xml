<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E00D0820"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="44dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#44FFFFFF"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:cornerRadius="20dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Learn Sign Language"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Spacer to balance the back button -->
            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Choose a sign to practice"
            android:textColor="#B8A9D9"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Scrollable word list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/wordsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- WORD 1: Hello -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="1"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/hello"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord1"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Hello"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 2: Please -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="2"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Please"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/please"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord2"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Please"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 3: Thank you -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="3"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thank You"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/thankyou"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord3"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Thank You"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 4: Yes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="4"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yes"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/yes"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord4"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Yes"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 5: No -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="5"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/no"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord5"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice No"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 6: Water -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="6"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Water"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/water"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord6"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Water"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 7: Mom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="7"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mom"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/mom"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord7"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Mom"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 8: Dad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="8"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dad"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/dad"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord8"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Dad"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 9: Food -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:layout_marginBottom="14dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="9"
                            android:textColor="#A78BFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/food"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord9"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Food"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- WORD 10: Drink -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_purple"
                        android:layout_marginEnd="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="10"
                            android:textColor="#A78BFA"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drink"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:src="@drawable/drink"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="#2D1B69"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnWord10"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="#7C3AED"
                    android:text="Practice Drink"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="12dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
